# ============================================================================
# Veni AI Report Factory — On-Premise Configuration (Pivot v3)
# ============================================================================

# ------ App Configuration ------
APP_ENV=development
APP_NAME=Veni AI Report Factory
API_PREFIX=
API_VERSION=v1
REPORT_FACTORY_DEFAULT_LOCALE=tr-TR

# ------ Database & Vector DB (PostgreSQL + pgvector) ------
DATABASE_URL=postgresql+asyncpg://vector_user1:vector_78s64+w2@10.144.100.204:25432/vectordb1
DATABASE_ALLOW_LOCAL_DEV=true
# Fallback untuk local development
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/sustainability

# ------ pgvector Configuration (Semantic Search) ------
PGVECTOR_HOST=10.144.100.204
PGVECTOR_PORT=25432
PGVECTOR_USER=vector_user1
PGVECTOR_PASSWORD=vector_78s64+w2
PGVECTOR_DATABASE=vectordb1
PGVECTOR_EMBEDDING_DIMENSION=1024  # Jina v4 output dimension

# ------ LLM Runtime — vLLM (Local, OpenAI-compatible) ------
VLLM_BASE_URL=http://localhost:8821/v1
VLLM_API_KEY=not-needed
VLLM_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
VLLM_TIMEOUT_SECONDS=180

# LLM Generation Rules
LLM_GENERATION_MAX_TOKENS=2048
LLM_GENERATION_TEMPERATURE=0.7
LLM_BATCH_WORKER_TIMEOUT_SECONDS=180
LLM_BATCH_WORKER_RETRY_COUNT=3
LLM_BATCH_WORKER_RETRY_BASE_SECONDS=5

# ------ Redis (Queue + Realtime State) ------
REDIS_HOST=10.144.100.204
REDIS_PORT=46379
REDIS_PASSWORD=O*+78sYtsr
REDIS_URL=redis://:O*+78sYtsr@10.144.100.204:46379/0

# ARQ Queue Configuration
ARQ_QUEUE_NAME=arq:queue
ARQ_WORKER_CONCURRENCY=4
ARQ_JOB_TIMEOUT_SECONDS=180
ARQ_JOB_RETRY_COUNT=3
ARQ_JOB_RETRY_BASE_SECONDS=5
ARQ_JOB_RETRY_MAX_DEFER_SECONDS=45

# ------ Jina Embedding (Multimodal: Text + Image) ------
JINA_EMBEDDING_BASE=https://jina-embedding.aiops.albarakaturk.local
JINA_EMBEDDING_MODEL=jina-embedding-v4
JINA_TEXT_ENDPOINT=/embed/text
JINA_IMAGE_ENDPOINT=/embed/image

# ------ MinIO Storage (Normal Bucket, No WORM) ------
MINIO_ENDPOINT=http://10.144.100.204:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=report-uploads  # Excel, images
MINIO_BUCKET_SNAPSHOTS=report-snapshots  # Published report snapshots

# Alternative: Local Filesystem Storage
STORAGE_USE_LOCAL=true
LOCAL_STORAGE_ROOT=apps/api/storage

# ------ Hocuspocus Realtime Collaboration Server ------
HOCUSPOCUS_HOST=http://localhost:1234
HOCUSPOCUS_WS_URL=ws://localhost:1234
HOCUSPOCUS_JWT_SECRET=your-jwt-secret-change-in-production

# ------ Frontend Configuration ------
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://127.0.0.1:1234

# ------ CORS & Security ------
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# ------ Report Configuration ------
REPORT_TEMPLATE_DEFAULT_VERSION=pivot-v3
REPORT_MAX_SECTION_LENGTH=5000
REPORT_AUTO_SAVE_INTERVAL_SECONDS=60

# ------ Audit & Logging ------
LOG_LEVEL=INFO
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# ------ Development & Testing ------
PLAYWRIGHT_WEB_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_API_BASE_URL=http://127.0.0.1:8000
DEMO_MODE=false

# ------ Health Check ------
HEALTH_CHECK_VLLM_ENABLED=true
HEALTH_CHECK_PGVECTOR_ENABLED=true
HEALTH_CHECK_REDIS_ENABLED=true
HEALTH_CHECK_JINA_ENABLED=true
HEALTH_CHECK_TIMEOUT_SECONDS=5
