{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "apps/web/src/**/*.{ts,tsx}",
    "packages/**/*.{ts,tsx}"
  ],
  "project": [
    "apps/web/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "packages/**/*.{ts,tsx,js,jsx,mjs,cjs}"
  ],
  "ignore": [
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.gitkeep"
  ]
}
